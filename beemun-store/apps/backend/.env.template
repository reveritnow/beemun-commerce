NODE_ENV=production

# Required: managed Postgres connection string from Render, Railway, Koyeb, Neon, Supabase, etc.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

# Required: comma-separated storefront origins that may call the Store API.
# Include your Vercel production URL and any preview/custom domains you use.
STORE_CORS=https://your-beemun-storefront.vercel.app,http://localhost:8000,http://localhost:3000

# Required: comma-separated Admin/Auth origins.
# Include the backend domain because Medusa Admin is served by the backend in production.
ADMIN_CORS=https://your-medusa-backend.example.com,http://localhost:9000,http://localhost:5173
AUTH_CORS=https://your-medusa-backend.example.com,http://localhost:9000,http://localhost:5173

# Required: generate strong unique values for production.
JWT_SECRET=replace-with-a-long-random-secret
COOKIE_SECRET=replace-with-a-long-random-secret

# Optional: set if your provider includes Redis.
REDIS_URL=

DB_NAME=beemun-medusa
